{
  "name": "subjecto",
  "version": "0.0.61",
  "description": "A minimalistic state management library with tiny bundle size (0.6KB core, 1.8KB full)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "prepare": "husky && if [ -d 'dist' ]; then rm -rf dist && npm run build; fi",
    "watch": "tsup --watch",
    "build": "tsup",
    "build:old": "tsc -b ./tsconfig.cjs.json ./tsconfig.esm.json ./tsconfig.types.json",
    "test": "jest",
    "lint": "eslint",
    "size": "npm run build && size-limit"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./helpers": {
      "import": {
        "types": "./dist/helpers.d.ts",
        "default": "./dist/helpers.js"
      },
      "require": {
        "types": "./dist/helpers.d.cts",
        "default": "./dist/helpers.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    }
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "testRegex": "(/src/__tests__/.*|(\\.|/)(test|spec))\\.[jt]sx?$",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/src/subject.ts",
      "**/src/deepSubject.ts",
      "**/src/react/**/*.ts"
    ],
    "moduleNameMapper": {
      "^@/types/paths$": "<rootDir>/src/react/types",
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulbrie/subjecto.git"
  },
  "bugs": {
    "url": "https://github.com/paulbrie/subjecto/issues"
  },
  "homepage": "https://github.com/paulbrie/subjecto#readme",
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "state",
    "management",
    "subscribe",
    "data",
    "store"
  ],
  "author": "Paul Brie",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "esbuild": "^0.27.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
